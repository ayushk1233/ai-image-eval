APP_NAME=AI Evaluation Platform
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite:///./data/evaluation.db

OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

DEFAULT_PROVIDER=openrouter
OPENAI_IMAGE_MODEL=openai/gpt-5-image-mini
GEMINI_25_MODEL=google/gemini-2.5-flash-image
GEMINI_31_MODEL=google/gemini-3.1-flash-image-preview

IMAGE_STORAGE_PATH=generated_images
LOG_LEVEL=INFO
